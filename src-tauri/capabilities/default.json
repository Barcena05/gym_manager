{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    "core:webview:allow-set-webview-zoom",
    "core:webview:allow-get-all-webviews",
    "core:window:allow-start-dragging"
  ]
}
